{
	"name": "n8n-nodes-piperun-openapi",
	"version": "0.2.2",
	"description": "PipeRun CRM API integration for n8n",
	"license": "MIT",
	"homepage": "https://github.com/LesserWords/n8n-nodes-piperun-openapi",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "LesserWords"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/LesserWords/n8n-nodes-piperun-openapi.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"getPiperunSchema": "node -e \"fetch('https://developers.pipe.run/openapi/686d5ab389846000619e863f').then(r => r.text()).then(t => require('fs').writeFileSync('nodes/Piperun/Piperun.openapi.json', t))"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PiperunApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/PiperunApi/PiperunApi.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"@devlikeapro/n8n-openapi-node": "^0.1.4"
	},
	"volta": {
		"node": "22.22.2",
		"npm": "11.13.0"
	}
}
